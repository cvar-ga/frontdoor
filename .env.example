# Copy this file to .env and fill in your Gemini API key.
# You can also paste a key directly in the UI at runtime instead.
# IMPORTANT: leave the value blank if you don't have a key — do NOT keep the
# format hint as the value, or the server will send an invalid key to the API.

# Google Gemini           format: AIza...
GEMINI_API_KEY=

# Server port (default: 3001)
PORT=3001

# Comma-separated list of custom forbidden keywords (case-insensitive)
# Example: FORBIDDEN_KEYWORDS=acme-internal,project-x,confidential
FORBIDDEN_KEYWORDS=

# Sensitivity level: high | medium | low  (default: medium)
# high   — blocks HIGH + MEDIUM + LOW findings
# medium — blocks HIGH + MEDIUM findings
# low    — blocks HIGH findings only
SENSITIVITY=medium
